{
    "name": "@haawpc/sydev",
    "version": "0.4.2",
    "type": "module",
    "bin": {
        "sydev": "./bin/sydev.js"
    },
    "description": "SylixOS 开发环境快速部署工具",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev:cli": "pnpm --filter @sydev/cli dev",
        "build": "pnpm -r build",
        "build:pkg": "tsup && node scripts/prepare-pkg.js",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "type-check": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "tsup": "^8.5.1",
        "tsx": "^4.0.0",
        "typescript": "^5.9.0",
        "vitest": "^3.0.0"
    }
}
